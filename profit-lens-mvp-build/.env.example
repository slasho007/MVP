# ---- Runtime ----
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# ---- Public URLs ----
# APP_URL: publicly reachable URL of the API (OAuth redirect + webhooks).
# WEB_URL: publicly reachable URL of the embedded frontend.
APP_URL=https://your-api-domain.example.com
WEB_URL=https://your-web-domain.example.com

# ---- Infrastructure ----
DATABASE_URL=postgresql://profitlens:profitlens@localhost:5432/profitlens?schema=public
REDIS_URL=redis://localhost:6379

# ---- Shopify app credentials (Partner Dashboard) ----
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_SCOPES=read_orders,read_products
SHOPIFY_API_VERSION=2025-01

# ---- Secrets ----
# At least 32 characters. Generate with: openssl rand -hex 32
COOKIE_SECRET=change-me-to-a-random-string-of-32-plus-characters

# ---- Frontend build-time vars (Vite) ----
VITE_SHOPIFY_API_KEY=your-shopify-api-key
VITE_API_URL=https://your-api-domain.example.com
