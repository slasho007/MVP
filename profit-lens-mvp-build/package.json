{
  "name": "profitlens",
  "version": "1.0.0",
  "private": true,
  "description": "ProfitLens - Shopify embedded SaaS that detects hidden profit leaks for merchants",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @profitlens/web dev",
    "dev:api": "pnpm --filter @profitlens/api dev",
    "dev:worker": "pnpm --filter @profitlens/api dev:worker",
    "dev:web": "pnpm --filter @profitlens/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @profitlens/api db:generate",
    "db:migrate": "pnpm --filter @profitlens/api db:migrate",
    "db:deploy": "pnpm --filter @profitlens/api db:deploy"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.79.2",
    "fastify": "^5.9.0",
    "ioredis": "^5.11.1",
    "pino": "^9.14.0",
    "zod": "^3.25.76"
  }
}
